https://leetcode.com/problems/keyboard-row/description/?envType=problem-list-v2&envId=string


class Solution {
    public String[] findWords(String[] words) {
        String s1 = "qwertyuiop";
        String s2 = "asdfghjkl";
        String s3 = "zxcvbnm";
        List<String> res = new ArrayList<>();
        for (String w : words) {
            String lower = w.toLowerCase(); 
            String row;
            char first = lower.charAt(0);
            if (s1.indexOf(first) != -1) 
                row = s1;
            else if (s2.indexOf(first) != -1) 
                row = s2;
            else 
                row = s3;
            boolean valid = true;
            for (int i = 1; i < lower.length(); i++) {
                if (row.indexOf(lower.charAt(i)) == -1) {
                    valid = false;
                    break;
                }
            }
            if (valid) 
                res.add(w);
        }
        return res.toArray(new String[0]);
    }
}
