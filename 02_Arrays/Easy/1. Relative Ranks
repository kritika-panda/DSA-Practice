import java.util.Arrays;

class Solution {
    public String[] findRelativeRanks(int[] score) {
        int n = score.length;
        String[] res = new String[n];
        
        // Create an index array: [0, 1, 2, ..., n-1]
        Integer[] indices = new Integer[n];
        for (int i = 0; i < n; i++) {
            indices[i] = i;
        }
        
        // Sort indices based on their actual scores in descending order
        Arrays.sort(indices, (a, b) -> score[b] - score[a]);
        
        // Assign ranks based on the sorted positions
        for (int i = 0; i < n; i++) {
            int originalIdx = indices[i];
            if (i == 0) {
                res[originalIdx] = "Gold Medal";
            } else if (i == 1) {
                res[originalIdx] = "Silver Medal";
            } else if (i == 2) {
                res[originalIdx] = "Bronze Medal";
            } else {
                res[originalIdx] = String.valueOf(i + 1);
            }
        }
        
        return res;
    }
}
