class Solution {
    public ListNode deleteDuplicates(ListNode head) {
        HashSet<Integer> hs=new HashSet<>();
        ListNode temp=head;
        ListNode prev=head;
        while(temp!=null)
        {
            if(!hs.add(temp.val))
                prev.next=temp.next;
            else
                prev=temp;
            temp=temp.next;
        }
        return head;
    }
}
